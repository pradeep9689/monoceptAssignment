package com.monocept.test;

import com.monocept.model.InputValidator;

public class InputValidatorTest {
	public static void runTests() {
        
        String[] usernames = {"", "a", "ab", "abc", "thisisaverylongusername", "validuser"};
        for (String username : usernames) {
            boolean result = InputValidator.validateUsername(username);
            System.out.println("Username '" + username + "': " + (result ? "Valid" : "Invalid"));
        }

        // Test cases for password
        String[] passwords = {"", "short", "validpassword", "thisisaverylongpasswordthatexceedsthemaximumlength", "GoodPass123"};
        for (String password : passwords) {
            boolean result = InputValidator.validatePassword(password);
            System.out.println("Password '" + password + "': " + (result ? "Valid" : "Invalid"));
        }

        // Test cases for email
        String[] emails = {"", "a@b.c", "short@e.co", "valid.email@example.com", "thisisaverylongemailaddress@thatexceedsthemaximumallowedlength.com", "missingatsign.com", "missingdot@com"};
        for (String email : emails) {
            boolean result = InputValidator.validateEmail(email);
            System.out.println("Email '" + email + "': " + (result ? "Valid" : "Invalid"));
        }
    }

    public static void main(String[] args) {
        runTests();
    }
}
