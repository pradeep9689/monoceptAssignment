package com.monocept.model;

public class InputValidator {
	
	
	public  boolean validateUsername(String username) {
    if (username != null && !username.isEmpty() && username.length() >= 3 && username.length() <= 20) {
        return true;
    }
    return false;
}

public  boolean validatePassword(String password) {
    if (password != null && !password.isEmpty() && password.length() >= 8 && password.length() <= 30) {
        return true;
    }
    return false;
}

public boolean validateEmail(String email) {
    if (email != null && !email.isEmpty() && email.length() >= 5 && email.length() <= 50 && email.contains("@") && email.contains(".")) {
        return true;
    }
    return false;
}
}